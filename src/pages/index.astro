---
import '../styles/global.css';

const days = ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'];

const recipes = [
  { emoji: '🍠', name: 'Greek Yogurt Sweet Potato Bowl', category: 'Kochen', kcal: '1300–1550 kcal' },
  { emoji: '🥞', name: 'Protein Pancake', category: 'Frühstück', kcal: '500–650 kcal' },
  { emoji: '🍪', name: 'Protein Cookie', category: 'Backen', kcal: '950–1150 kcal' },
];

const categoryColors: Record<string, string> = {
  Frühstück: 'bg-amber-100 text-amber-800',
  Kochen: 'bg-rose-100 text-rose-800',
  Backen: 'bg-orange-100 text-orange-800',
};
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Meal Prep</title>
	</head>
	<body class="bg-[#fdf6f0] text-stone-800 font-sans">
		<header class="bg-gradient-to-br from-rose-200 via-orange-100 to-amber-100 py-14 px-6 text-center shadow-sm">
			<h1 class="text-4xl font-bold tracking-tight text-stone-900">🍽️ Olivias Meal Prep</h1>
			<p class="mt-2 text-stone-600">Rezepte, Wochenplan &amp; Einkaufsliste an einem Ort</p>
		</header>

		<main class="max-w-5xl mx-auto px-4 py-10 space-y-12">
			<section>
				<h2 class="text-xl font-semibold mb-4 text-stone-900">Wochenplan</h2>
				<div class="flex gap-3 overflow-x-auto pb-2">
					{days.map((day) => (
						<div class="min-w-[140px] bg-white rounded-2xl shadow-sm p-4 flex-shrink-0">
							<div class="font-semibold text-stone-700 mb-3">{day}</div>
							<div class="space-y-2 text-sm">
								<div class="rounded-xl border border-dashed border-stone-200 text-stone-400 px-2 py-3 text-center">
									+ Rezept
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<section>
				<div class="flex items-center justify-between mb-4">
					<h2 class="text-xl font-semibold text-stone-900">Rezepte</h2>
					<a href="#" class="text-sm text-rose-600 hover:underline">Alle ansehen →</a>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
					{recipes.map((r) => (
						<div class="bg-white rounded-2xl shadow-sm p-5 hover:shadow-md transition-shadow">
							<div class="text-3xl mb-2">{r.emoji}</div>
							<div class="font-semibold text-stone-900">{r.name}</div>
							<div class="mt-2 flex items-center gap-2 text-xs">
								<span class={`px-2 py-1 rounded-full font-medium ${categoryColors[r.category]}`}>
									{r.category}
								</span>
								<span class="text-stone-500">{r.kcal}</span>
							</div>
						</div>
					))}
				</div>
			</section>

			<section>
				<div class="bg-white rounded-2xl shadow-sm p-5 flex items-center justify-between">
					<div>
						<h2 class="text-xl font-semibold text-stone-900">Einkaufsliste</h2>
						<p class="text-stone-500 text-sm mt-1">0 offene Artikel</p>
					</div>
					<a href="#" class="text-sm text-rose-600 hover:underline">Ansehen →</a>
				</div>
			</section>
		</main>
	</body>
</html>
