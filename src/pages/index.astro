---
import Layout from '../layouts/Layout.astro';
import { recipes, type RecipeCategory } from '../data/recipes';

const days = ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'];
const preview = recipes.slice(0, 3);

const categoryColors: Record<RecipeCategory, string> = {
  Frühstück: 'bg-amber-100 text-amber-800',
  Kochen: 'bg-rose-100 text-rose-800',
  Backen: 'bg-orange-100 text-orange-800',
};
---

<Layout title="Meal Prep">
  <header class="bg-gradient-to-br from-rose-200 via-orange-100 to-amber-100 py-14 px-6 text-center shadow-sm">
    <h1 class="text-4xl font-bold tracking-tight text-stone-900">🍽️ Olivias Meal Prep</h1>
    <p class="mt-2 text-stone-600">Rezepte, Meal Plan &amp; Einkaufsliste an einem Ort</p>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-stone-900">Meal Plan</h2>
        <a href="/wochenplan" class="text-sm text-rose-600 hover:underline">Ganze Woche ansehen →</a>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-2">
        {days.map((day) => (
          <a
            href="/wochenplan"
            class="min-w-[140px] bg-white rounded-2xl shadow-sm p-4 flex-shrink-0 block hover:shadow-md transition-shadow"
          >
            <div class="font-semibold text-stone-700 mb-3">{day}</div>
            <div class="space-y-2 text-sm">
              <div class="rounded-xl border border-dashed border-stone-200 text-stone-400 px-2 py-3 text-center">
                + Rezept
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-stone-900">Rezepte</h2>
        <a href="/rezepte" class="text-sm text-rose-600 hover:underline">Alle ansehen →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {preview.map((r) => (
          <a
            href={`/rezepte/${r.id}`}
            class="bg-white rounded-2xl shadow-sm p-5 hover:shadow-md transition-shadow block"
          >
            <div class="text-3xl mb-2">{r.emoji}</div>
            <div class="font-semibold text-stone-900">{r.name}</div>
            <div class="mt-2 flex items-center gap-2 text-xs">
              <span class={`px-2 py-1 rounded-full font-medium ${categoryColors[r.category]}`}>
                {r.category}
              </span>
              {r.calories && <span class="text-stone-500">{r.calories}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <a
        href="/einkaufsliste"
        class="bg-white rounded-2xl shadow-sm p-5 flex items-center justify-between hover:shadow-md transition-shadow"
      >
        <div>
          <h2 class="text-xl font-semibold text-stone-900">Einkaufsliste</h2>
          <p class="text-stone-500 text-sm mt-1">Automatisch aus deinem Meal Plan</p>
        </div>
        <span class="text-sm text-rose-600">Ansehen →</span>
      </a>
    </section>
  </main>
</Layout>
