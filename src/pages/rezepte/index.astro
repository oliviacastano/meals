---
import Layout from '../../layouts/Layout.astro';
import { recipes, type RecipeCategory } from '../../data/recipes';

const categories: RecipeCategory[] = ['Frühstück', 'Kochen', 'Backen'];
const categoryColors: Record<RecipeCategory, string> = {
  Frühstück: 'bg-amber-100 text-amber-800',
  Kochen: 'bg-rose-100 text-rose-800',
  Backen: 'bg-orange-100 text-orange-800',
};
---

<Layout title="Rezepte – Meal Prep">
  <main class="max-w-5xl mx-auto px-4 py-10 space-y-10">
    <h1 class="text-2xl font-bold text-stone-900">Rezepte</h1>

    {categories.map((cat) => {
      const items = recipes.filter((r) => r.category === cat);
      if (items.length === 0) return null;
      return (
        <section>
          <h2 class="text-lg font-semibold text-stone-800 mb-3">{cat}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map((r) => (
              <a
                href={`/rezepte/${r.id}`}
                class="bg-white rounded-2xl shadow-sm p-5 hover:shadow-md transition-shadow block"
              >
                <div class="text-3xl mb-2">{r.emoji}</div>
                <div class="font-semibold text-stone-900">{r.name}</div>
                <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                  <span class={`px-2 py-1 rounded-full font-medium ${categoryColors[r.category]}`}>
                    {r.category}
                  </span>
                  {r.calories && <span class="text-stone-500">{r.calories}</span>}
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>
